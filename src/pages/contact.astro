---
import Base from '../layouts/Base.astro';
---
<Base title="Contact & Hours" description="Book an appointment at Raffaello Salon. 132 Cumberland Street, 2nd Floor, Yorkville, Toronto. (416) 929-0021.">

  <div class="page-header dark-section">
    <div class="container">
      <span class="eyebrow reveal">132 Cumberland Street</span>
      <h1 class="reveal reveal-delay-1">Find Us.</h1>
    </div>
  </div>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-info reveal">
          <div class="info-block">
            <h2 class="info-label">Address</h2>
            <address>
              132 Cumberland Street<br />
              2nd Floor<br />
              Toronto, Ontario M5R 1A6
            </address>
            <p class="info-note">Located in the heart of Yorkville, above street level. Elevator access available.</p>
          </div>

          <div class="info-block">
            <h2 class="info-label">Phone</h2>
            <a href="tel:4169290021" class="phone-link">(416) 929-0021</a>
          </div>

          <div class="info-block">
            <h2 class="info-label">Email</h2>
            <a href="mailto:info@raffaellosalon.com" class="email-link">info@raffaellosalon.com</a>
          </div>

          <div class="info-block">
            <h2 class="info-label">Hours</h2>
            <dl class="hours-list">
              <div class="hours-row">
                <dt>Tuesday</dt>
                <dd>9:00 AM &ndash; 5:00 PM</dd>
              </div>
              <div class="hours-row">
                <dt>Wednesday</dt>
                <dd>9:00 AM &ndash; 5:00 PM</dd>
              </div>
              <div class="hours-row">
                <dt>Thursday</dt>
                <dd>9:00 AM &ndash; 7:00 PM</dd>
              </div>
              <div class="hours-row">
                <dt>Friday</dt>
                <dd>9:00 AM &ndash; 5:00 PM</dd>
              </div>
              <div class="hours-row">
                <dt>Saturday</dt>
                <dd>8:30 AM &ndash; 5:00 PM</dd>
              </div>
              <div class="hours-row closed">
                <dt>Sunday &ndash; Monday</dt>
                <dd>Closed</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="contact-cta reveal reveal-delay-1">
          <div class="cta-card">
            <span class="eyebrow">Book Your Appointment</span>
            <h2>Ready to come in?</h2>
            <p>Call us directly to speak with a team member and book your appointment. We do not offer online booking at this time.</p>
            <a href="tel:4169290021" class="btn btn-primary btn-large">(416) 929-0021</a>
            <p class="cta-note">Tuesday through Saturday. Thursday open late until 7 PM.</p>
          </div>

          <div class="map-container">
            <iframe
              title="Raffaello Salon location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2886.1!2d-79.3931!3d43.6712!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDQwJzE2LjMiTiA3OcKwMjMnMzUuMiJX!5e0!3m2!1sen!2sca!4v1"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="social-section">
    <div class="container">
      <div class="social-inner reveal">
        <h2>Follow the Work.</h2>
        <div class="social-links">
          <a href="https://www.facebook.com/raffaellosalon" target="_blank" rel="noopener noreferrer" class="social-link">
            Facebook
          </a>
          <a href="https://www.instagram.com/raffaellosalon" target="_blank" rel="noopener noreferrer" class="social-link">
            Instagram @raffaellosalon
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .page-header { padding: 10rem 0 5rem; }
  .page-header .eyebrow { color: var(--stone); display: block; margin-bottom: 1.5rem; }
  .page-header h1 { color: var(--parchment); }

  .contact-section { padding: clamp(4rem, 8vw, 7.5rem) 0; background: var(--parchment); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: start;
  }

  .info-block { margin-bottom: 3rem; }
  .info-block:last-child { margin-bottom: 0; }
  .info-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--stone);
    margin-bottom: 1rem;
  }
  address {
    font-style: normal;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--salon-black);
  }
  .info-note { font-size: 0.85rem; color: var(--stone); margin-top: 0.75rem; max-width: none; }
  .phone-link, .email-link {
    font-size: 1.25rem;
    color: var(--salon-black);
    text-decoration: none;
    border-bottom: 1px solid var(--salon-black);
    padding-bottom: 2px;
    transition: opacity 200ms ease;
  }
  .phone-link:hover, .email-link:hover { opacity: 0.6; }

  .hours-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(26,26,26,0.08);
  }
  .hours-row dt { color: var(--salon-black); }
  .hours-row dd { color: rgba(26,26,26,0.6); margin: 0; }
  .hours-row.closed dt, .hours-row.closed dd { color: var(--stone); }

  .cta-card {
    background: var(--salon-black);
    padding: 3rem;
    margin-bottom: 2rem;
  }
  .cta-card .eyebrow { color: var(--stone); display: block; margin-bottom: 1rem; }
  .cta-card h2 { color: var(--parchment); margin-bottom: 1rem; font-size: clamp(1.5rem, 2.5vw, 2rem); }
  .cta-card p { color: rgba(244,240,232,0.7); font-size: 0.9rem; margin-bottom: 2rem; max-width: none; }
  .btn-large { font-size: 1rem; padding: 1rem 2.5rem; }
  .cta-note { font-size: 0.8rem; color: var(--stone); margin-top: 1.25rem; margin-bottom: 0; max-width: none; }

  .map-container { overflow: hidden; }
  .map-container iframe { display: block; filter: grayscale(100%) contrast(1.1); }

  .social-section { padding: 5rem 0; background: var(--warm-white); border-top: 1px solid rgba(26,26,26,0.08); }
  .social-inner { display: flex; align-items: center; gap: 4rem; }
  .social-inner h2 { margin-bottom: 0; font-size: clamp(1.5rem, 2.5vw, 2.5rem); }
  .social-links { display: flex; gap: 2rem; flex-wrap: wrap; }
  .social-link {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--salon-black);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 200ms ease;
  }
  .social-link:hover { opacity: 0.5; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .social-inner { flex-direction: column; align-items: flex-start; gap: 2rem; }
  }
</style>
