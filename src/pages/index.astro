---
export const prerender = true;
import Base from '../layouts/Base.astro';
---
<Base title="Yorkville's Original Salon Since 1968">

  <!-- BEAT 1: HERO — no image, the restraint is the opening statement -->
  <section class="hero">
    <div class="container hero-content">
      <span class="eyebrow reveal">Yorkville, Toronto</span>
      <h1 class="reveal reveal-delay-1" id="hero-headline">Since 1968.</h1>
      <p class="hero-sub reveal reveal-delay-2">132 Cumberland Street. Yorkville.</p>
      <div class="hero-actions reveal reveal-delay-3">
        <a href="/contact" class="btn btn-primary">Book Appointment</a>
        <a href="tel:4169290021" class="btn btn-outline-ink">(416) 929-0021</a>
      </div>
    </div>
    <span class="rule hero-rule" aria-hidden="true"></span>
  </section>

  <!-- BEAT 2: THE FAMILY — masthead credit line, no stock photos -->
  <section class="family">
    <div class="container">
      <span class="eyebrow reveal">The Family</span>
      <h2 class="reveal reveal-delay-1">Three generations.<br />One family. Fifty-eight years in Yorkville.</h2>
      <div class="family-grid">
        <article class="family-member reveal">
          <img src="/raffaello-portrait.jpeg" alt="Raffaello Marrello, Founder" class="img-portrait img-bw" loading="lazy" />
          <p class="eyebrow">Founder</p>
          <h3>Raffaello Marrello</h3>
          <p>Known for innovative cutting methods and a lifetime dedicated to Italian technique, education, and creative evolution.</p>
        </article>
        <article class="family-member reveal reveal-delay-1">
          <img src="/christopher-portrait.jpg" alt="Christopher Marrello, Creative Director" class="img-portrait img-bw" loading="lazy" />
          <p class="eyebrow">Creative Director</p>
          <h3>Christopher Marrello</h3>
          <p>Modern eye, extensive editorial and stage experience. Clean lines, movement, contemporary form.</p>
        </article>
        <article class="family-member reveal reveal-delay-2">
          <img src="/mellissa-portrait.webp" alt="Mellissa Marrello, Colour Director" class="img-portrait img-bw" loading="lazy" />
          <p class="eyebrow">Colour Director</p>
          <h3>Mellissa Marrello</h3>
          <p>Refined, dimensional colour work. Artistry balanced with technical precision.</p>
        </article>
      </div>
      <div class="family-cta reveal">
        <a href="/team" class="btn btn-outline-ink">Meet the Family</a>
      </div>
    </div>
  </section>

  <!-- BEAT 3: SERVICES — spare price list, not cards -->
  <section class="services section-bone">
    <div class="container">
      <span class="eyebrow reveal">The Work</span>
      <h2 class="reveal reveal-delay-1">Hair. Colour. Spa.</h2>

      <div class="price-block reveal">
        <h4>Hair &amp; Style</h4>
        <div class="price-row"><span>Women's cut, Raffaello</span><span>from $175</span></div>
        <div class="price-row"><span>Women's cut, Christopher</span><span>from $130</span></div>
        <div class="price-row"><span>Women's cut, team</span><span>from $110</span></div>
        <div class="price-row"><span>Men's cut, Raffaello</span><span>$120</span></div>
        <div class="price-row"><span>Men's cut, Christopher</span><span>$70</span></div>
        <div class="price-row"><span>Men's cut, team</span><span>from $60</span></div>
      </div>

      <div class="price-block reveal reveal-delay-1">
        <h4>Colour</h4>
        <div class="price-row"><span>Root touch-up, Mellissa</span><span>from $150</span></div>
        <div class="price-row"><span>Full highlights, Mellissa</span><span>from $350</span></div>
        <div class="price-row"><span>Balayage</span><span>by consultation</span></div>
        <div class="price-row"><span>Colour correction</span><span>by consultation</span></div>
        <div class="price-row"><span>Colour, team</span><span>from $100</span></div>
      </div>

      <div class="price-block spa-block reveal reveal-delay-2">
        <div class="spa-text">
          <h4>Spa</h4>
          <p class="spa-copy">Scalp treatments, facials, and skin rejuvenation. Full menu on request.</p>
        </div>
        <img src="/spa-treatment.jpg" alt="Spa treatment at Raffaello Salon" class="spa-image img-bw" loading="lazy" />
      </div>

      <p class="micro-cta reveal">Call <a href="tel:4169290021">(416) 929-0021</a> for full pricing and availability.</p>
    </div>
  </section>

  <!-- BEAT 4: THE PRESS — this is Raffaello, verbatim -->
  <section class="press section-ink">
    <div class="container">
      <span class="eyebrow reveal">The Press</span>
      <h2 class="reveal reveal-delay-1">The work speaks.</h2>

      <div class="press-layout">
        <div class="press-left">
          <ul class="press-list reveal reveal-delay-2">
            <li>Featured in Japan's Passion Magazine — the only Canadian hairstylist selected.</li>
            <li>Cover and six-page editorial, Spain's Peluquerias Magazine.</li>
            <li>Styled Helena Bonham Carter for <em>The Wings of the Dove</em>.</li>
            <li>Styled Roberto Benigni for <em>Life Is Beautiful</em>.</li>
            <li>Clients include Faye Dunaway, Joan Rivers, James Cameron, Minnie Driver, and Liv Ullmann.</li>
          </ul>

          <blockquote class="press-quote reveal">
            &ldquo;When you do styles you limit yourself to some people. When you do people, hairstyles are unlimited.&rdquo;
            <cite>— Raffaello Marrello, 1991</cite>
          </blockquote>

          <blockquote class="press-quote press-quote-secondary reveal reveal-delay-1">
            &ldquo;Every piece I create is a question posed to the universe, and a response that is uniquely my own.&rdquo;
            <cite>— Raffaello Marrello</cite>
          </blockquote>
        </div>
        <div class="press-right reveal reveal-delay-1">
          <img src="/press-trim-cover-1968.webp" alt="TRIM, Canada's Largest Beauty Magazine, archival cover" class="press-archival-img" loading="lazy" />
          <p class="press-caption">From the archive, 1968.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BEAT 4.5: FIELDS OF GOLD — the real, dramatic, unusual story -->
  <section class="fields-of-gold">
    <div class="container fog-inner">
      <div class="reveal">
        <span class="eyebrow">A True Story</span>
        <h2>Fields of Gold.</h2>
        <p>In 1986, Raffaello painted a six-foot by seven-foot oil on canvas of wildflowers. He named it Fields of Gold, for his wife Christine. A decade later, Sting released a song with the same name.</p>
        <p>The painting has hung in his home for almost forty years. This is the kind of attention that goes into everything he touches.</p>
      </div>
      <blockquote class="fog-quote reveal reveal-delay-1">
        &ldquo;The extraordinary agility and daring display of dazzling beauty in wildflowers, devoid of human intervention, captivated me.&rdquo;
        <cite>— Raffaello Marrello</cite>
      </blockquote>
    </div>
  </section>

  <!-- BEAT 5: VISIT -->
  <section class="visit section-ink">
    <div class="container visit-inner">
      <div class="visit-text reveal">
        <span class="eyebrow">Visit</span>
        <h2>132 Cumberland Street.<br />2nd Floor, Yorkville.</h2>
        <div class="visit-actions">
          <a href="/contact" class="btn btn-primary">Book Appointment</a>
          <a href="tel:4169290021" class="btn btn-outline-paper">Call Us</a>
        </div>
      </div>
      <div class="visit-hours reveal reveal-delay-1">
        <span class="rule"></span>
        <ul class="hours-list">
          <li><span>Tuesday</span><span>9am – 5pm</span></li>
          <li><span>Wednesday</span><span>9am – 5pm</span></li>
          <li><span>Thursday</span><span>9am – 7pm</span></li>
          <li><span>Friday</span><span>9am – 5pm</span></li>
          <li><span>Saturday</span><span>8:30am – 5pm</span></li>
          <li class="closed"><span>Sunday – Monday</span><span>Closed</span></li>
        </ul>
      </div>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 92svh;
    display: flex;
    align-items: center;
    padding-top: 76px;
  }
  .hero-content { max-width: 900px; }
  .hero-content .eyebrow { display: block; margin-bottom: 1.5rem; }
  #hero-headline { margin-bottom: 1.5rem; }
  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 500;
    color: var(--graphite);
    margin-bottom: 2.5rem;
    max-width: none;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-rule { position: absolute; bottom: 0; left: clamp(1.5rem, 4vw, 3rem); width: 40px; }

  /* FAMILY */
  .family h2 { margin: 1rem 0 4.5rem; max-width: 20ch; }
  .family-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; margin-bottom: 3.5rem; }
  .family-member img { margin-bottom: 1.5rem; }
  .family-member-text { display: flex; flex-direction: column; justify-content: flex-end; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.08); }
  .family-member .eyebrow { margin-bottom: 0.5rem; }
  .family-member h3 { margin-bottom: 0.75rem; }
  .family-member p { font-size: 0.9rem; color: var(--graphite); }
  .family-cta { text-align: center; }
  @media (max-width: 900px) { .family-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

  /* SERVICES / PRICE LIST */
  .services h2 { margin: 1rem 0 4rem; }
  .price-block { margin-bottom: 3rem; max-width: 700px; }
  .price-block h4 { margin-bottom: 1.25rem; letter-spacing: 0.02em; }
  .price-row {
    display: flex; justify-content: space-between;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    font-size: 0.95rem;
  }
  .price-row span:last-child { color: var(--graphite); }
  .spa-copy { color: var(--graphite); }
  .micro-cta { font-size: 0.9rem; color: var(--graphite); margin-top: 2rem; }
  .micro-cta a { text-decoration: underline; color: var(--ink); }
  .spa-block { display: flex; justify-content: space-between; align-items: flex-end; gap: 3rem; max-width: none; }
  .spa-image { width: 220px; aspect-ratio: 4/5; object-fit: cover; flex-shrink: 0; }
  @media (max-width: 700px) { .spa-block { flex-direction: column; align-items: flex-start; } .spa-image { width: 100%; } }

  /* PRESS */
  .press h2 { margin: 1rem 0 3.5rem; }
  .press-layout { display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start; }
  .press-right { align-self: start; }
  .press-archival-img { width: 100%; filter: sepia(0.15) contrast(1.05); }
  .press-caption { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.75rem; letter-spacing: 0.05em; }
  @media (max-width: 900px) { .press-layout { grid-template-columns: 1fr; gap: 2.5rem; } }
  .press-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; margin-bottom: 4.5rem; max-width: 640px; }
  .press-list li { font-size: 1rem; color: rgba(255,255,255,0.75); padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .press-quote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    line-height: 1.3;
    max-width: 16ch;
    margin-bottom: 4rem;
  }
  .press-quote-secondary { font-size: clamp(1.125rem, 2vw, 1.5rem); opacity: 0.7; max-width: 20ch; }
  .press-quote cite { display: block; font-family: var(--font-body); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.08em; color: rgba(255,255,255,0.45); font-style: normal; margin-top: 1.25rem; }

  /* FIELDS OF GOLD */
  .fields-of-gold { background: var(--bone); }
  .fog-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .fog-inner h2 { margin: 1rem 0 1.5rem; }
  .fog-inner p { margin-bottom: 1rem; color: var(--graphite); }
  .fog-quote {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.25vw, 1.75rem);
    font-weight: 500;
    line-height: 1.4;
  }
  .fog-quote cite { display: block; font-family: var(--font-body); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.08em; color: var(--graphite); font-style: normal; margin-top: 1.25rem; }
  @media (max-width: 900px) { .fog-inner { grid-template-columns: 1fr; gap: 2.5rem; } }

  /* VISIT */
  .visit-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .visit-text h2 { margin: 1rem 0 2.5rem; }
  .visit-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hours-list { list-style: none; }
  .hours-list li { display: flex; justify-content: space-between; padding: 0.875rem 0; border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 0.875rem; color: rgba(255,255,255,0.55); }
  .hours-list li span:last-child { color: var(--paper); }
  .hours-list .closed { opacity: 0.4; }
  @media (max-width: 900px) { .visit-inner { grid-template-columns: 1fr; gap: 3rem; } }
</style>

<script>
  const headline = document.getElementById('hero-headline');
  if (headline) {
    const text = headline.textContent || '';
    headline.innerHTML = text.split('').map(char =>
      `<span class="char" style="display:inline-block;opacity:0;transform:translateY(20px)">${char === ' ' ? '&nbsp;' : char}</span>`
    ).join('');
    const chars = headline.querySelectorAll('.char');
    chars.forEach((char, i) => {
      setTimeout(() => {
        (char as HTMLElement).style.transition = `opacity 400ms cubic-bezier(0.22, 1, 0.36, 1), transform 400ms cubic-bezier(0.22, 1, 0.36, 1)`;
        (char as HTMLElement).style.opacity = '1';
        (char as HTMLElement).style.transitionDelay = `${i * 0.03}s`;
        (char as HTMLElement).style.transform = 'translateY(0)';
      }, 200);
    });
  }
</script>
