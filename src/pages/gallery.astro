---
export const prerender = true;
import Base from '../layouts/Base.astro';
---
<Base title="Gallery" description="The best recent work at Raffaello Salon, Yorkville, Toronto — colour, cutting, and finished style.">
  <div class="page-header section-ink">
    <div class="container">
      <span class="eyebrow reveal">Recent Work</span>
      <h1 class="reveal reveal-delay-1">The Gallery.</h1>
      <p class="header-sub reveal reveal-delay-2">This is the work happening now. For fifty-eight years of it, see the <a href="/history">History</a>.</p>
    </div>
  </div>
  <section class="gallery-section">
    <div class="container">
      <div class="gallery-grid" data-reveal-group>
        <figure class="gallery-item gallery-item-tall">
          <div class="img-reveal">
            <img src="/gallery-client-1.jpg" alt="Balayage and blowout at Raffaello Salon" class="img-gallery" loading="eager" />
          </div>
          <figcaption>Balayage, finished blowout</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-4.jpg" alt="Colour and movement at Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Colour and movement</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-client-4.jpg" alt="Warm balayage and finished blowout, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Warm balayage, finished style</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-nancy-2.jpg" alt="Precision bob, colour detail" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Precision bob, colour detail</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/portfolio-chris-1.jpg" alt="Colour and cut by Christopher Marrello" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Christopher Marrello, in the chair</figcaption>
        </figure>
        <figure class="gallery-item gallery-item-wide">
          <div class="img-reveal">
            <img src="/gallery-indie-1.jpg" alt="Colour movement from behind, Raffaello Salon storefront reflected" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Colour, from behind — Cumberland Street</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-chris-street.jpg" alt="Finished bob by Christopher Marrello, Yorkville" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Christopher Marrello, finished work</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-client-2.jpg" alt="Blowout styling at Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Styling, in progress</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-6.jpg" alt="Finished balayage, Raffaello Salon window light" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Finished balayage, window light</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-client-3.jpg" alt="Finished balayage at Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Finished balayage</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/portfolio-chris-2.jpg" alt="Finished blowout by Christopher Marrello" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Movement, finished work</figcaption>
        </figure>
        <figure class="gallery-item gallery-item-wide">
          <div class="img-reveal">
            <img src="/gallery-indie-7.jpg" alt="Finished colour and blowout, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Finished colour, full blowout</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-client-5.jpg" alt="Silver colour and precision bob, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Silver colour, precision bob</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-2.jpg" alt="Blonde balayage from behind, Raffaello Salon storefront window" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Blonde balayage, from behind</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-3.jpg" alt="Soft finished waves, profile, Raffaello Salon storefront window" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Soft waves, storefront light</figcaption>
        </figure>
        <figure class="gallery-item gallery-item-tall">
          <div class="img-reveal">
            <img src="/gallery-indie-5.jpg" alt="Full volume finished blowout, close portrait, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Volume and dimension, finished blowout</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-client-6.jpg" alt="Caramel balayage from behind, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Caramel balayage, from behind</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-8.jpg" alt="Golden blonde soft waves, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Golden blonde, soft glam waves</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-9.jpg" alt="Golden blonde full volume finish, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Golden blonde, full volume</figcaption>
        </figure>
        <figure class="gallery-item">
          <div class="img-reveal">
            <img src="/gallery-indie-10.jpg" alt="Golden blonde finished blowout, smiling, Raffaello Salon" class="img-gallery" loading="lazy" />
          </div>
          <figcaption>Golden blonde, finished blowout</figcaption>
        </figure>
      </div>
      <p class="gallery-note reveal">More from the archive on request. Follow <a href="https://instagram.com/raffaellosalon" target="_blank" rel="noopener">@raffaellosalon</a> for current work. For fifty-eight years of history, visit the <a href="/history">History</a> page.</p>
    </div>
  </section>
</Base>

<style>
  .page-header { padding: 10rem 0 5rem; }
  .page-header .eyebrow { display: block; margin-bottom: 1.5rem; }
  .header-sub { font-family: var(--font-display); font-size: 1.125rem; color: rgba(255,255,255,0.55); max-width: none; }
  .header-sub a { color: var(--paper); text-decoration: underline; }
  .gallery-section { padding: clamp(4rem, 8vw, 7.5rem) 0; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-bottom: 3rem;
  }
  .gallery-item { position: relative; overflow: hidden; }
  .gallery-item-tall { grid-row: span 2; }
  .gallery-item-wide { grid-column: span 2; }
  .gallery-item .img-reveal { width: 100%; height: 100%; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-dramatic) var(--ease-primary); }
  .gallery-item:hover img { transform: scale(1.05); }
  .gallery-item figcaption {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 1rem 1.25rem;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    color: var(--paper);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--dur-micro) var(--ease-primary), transform var(--dur-micro) var(--ease-primary);
  }
  .gallery-item:hover figcaption { opacity: 1; transform: none; }
  .gallery-item figcaption a { color: var(--paper); text-decoration: underline; }
  .gallery-note { color: var(--graphite); font-size: 0.9rem; }
  .gallery-note a { text-decoration: underline; color: var(--ink); }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: 1fr 1fr; }
    .gallery-item-wide { grid-column: span 2; }
    .gallery-item-tall { grid-row: span 1; }
    .gallery-item figcaption { opacity: 1; transform: none; background: linear-gradient(to top, rgba(0,0,0,0.55), transparent); }
  }
</style>
