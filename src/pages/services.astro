---
export const prerender = true;
import Base from '../layouts/Base.astro';
---
<Base title="Services & Pricing" description="Hair, colour, and spa services at Raffaello Salon, Yorkville Toronto since 1968.">

  <div class="page-header section-ink">
    <div class="container">
      <span class="eyebrow reveal">132 Cumberland Street</span>
      <h1 class="reveal reveal-delay-1">Hair. Colour. Spa.</h1>
    </div>
  </div>

  <section id="hair" class="service-section section-bone">
    <div class="container">
      <span class="eyebrow reveal">Hair &amp; Style</span>
      <span class="rule reveal"></span>
      <div class="price-block reveal">
        <div class="price-row"><span>Women's cut, Raffaello</span><span>from $175</span></div>
        <div class="price-row"><span>Women's cut, Christopher</span><span>from $130</span></div>
        <div class="price-row"><span>Women's cut, team</span><span>from $110</span></div>
        <div class="price-row"><span>Men's cut, Raffaello</span><span>$120</span></div>
        <div class="price-row"><span>Men's cut, Christopher</span><span>$70</span></div>
        <div class="price-row"><span>Men's cut, team</span><span>from $60</span></div>
        <div class="price-row"><span>Blowout &amp; styling</span><span>by consultation</span></div>
        <div class="price-row"><span>Bridal &amp; special occasion</span><span>by consultation</span></div>
      </div>
      <a href="/contact" class="btn btn-outline-ink reveal">Book Appointment</a>
    </div>
  </section>

  <section id="colour" class="service-section">
    <div class="container">
      <span class="eyebrow reveal">Colour</span>
      <span class="rule reveal"></span>
      <div class="price-block reveal">
        <div class="price-row"><span>Root touch-up, Mellissa</span><span>from $150</span></div>
        <div class="price-row"><span>Full highlights, Mellissa</span><span>from $350</span></div>
        <div class="price-row"><span>Balayage</span><span>by consultation</span></div>
        <div class="price-row"><span>Colour correction</span><span>by consultation</span></div>
        <div class="price-row"><span>Colour, team</span><span>from $100</span></div>
        <div class="price-row"><span>Gloss &amp; toning</span><span>from $45</span></div>
      </div>
      <a href="/contact" class="btn btn-outline-ink reveal">Book Appointment</a>
    </div>
  </section>

  <section id="spa" class="service-section section-bone">
    <div class="container">
      <span class="eyebrow reveal">Spa</span>
      <span class="rule reveal"></span>
      <p class="spa-intro reveal">Full-service spa treatments at the same location as your hair appointment. One visit, complete care.</p>
      <ul class="spa-list reveal">
        <li>Facials</li>
        <li>Dermaplaning</li>
        <li>Oxygen treatments</li>
        <li>Microcurrent lifts</li>
        <li>Waxing</li>
        <li>Manicures &amp; pedicures</li>
      </ul>
      <p class="micro-cta reveal">Full menu and pricing on request. Call <a href="tel:4169290021">(416) 929-0021</a>.</p>
      <a href="/contact" class="btn btn-outline-ink reveal">Book Appointment</a>
    </div>
  </section>

</Base>

<style>
  .page-header { padding: 10rem 0 5rem; }
  .page-header .eyebrow { display: block; margin-bottom: 1.5rem; }

  .service-section .eyebrow { display: block; margin-bottom: 1rem; }
  .service-section .rule { margin-bottom: 3rem; }

  .price-block { max-width: 700px; margin-bottom: 3rem; }
  .price-row {
    display: flex; justify-content: space-between;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    font-size: 0.95rem;
  }
  .price-row span:last-child { color: var(--graphite); }

  .spa-intro { max-width: 55ch; color: var(--graphite); margin-bottom: 2.5rem; }
  .spa-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 500px;
    margin-bottom: 2rem;
  }
  .spa-list li { padding: 0.75rem 0; border-bottom: 1px solid rgba(0,0,0,0.08); font-size: 0.9rem; }
  .micro-cta { font-size: 0.9rem; color: var(--graphite); margin-bottom: 2.5rem; }
  .micro-cta a { text-decoration: underline; color: var(--ink); }

  @media (max-width: 600px) { .spa-list { grid-template-columns: 1fr; } }
</style>
