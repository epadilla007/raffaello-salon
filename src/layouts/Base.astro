---
export interface Props {
  title: string;
  description?: string;
  hasDarkHero?: boolean;
}

const {
  title,
  description = "Raffaello Salon — Yorkville's original salon since 1968. Hair, colour, and spa services at 132 Cumberland Street, Toronto.",
  hasDarkHero = false
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Raffaello Salon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />
  <style is:global>
    /* === DESIGN TOKENS === */
    :root {
      --salon-black: #1A1A1A;
      --parchment: #F4F0E8;
      --raffaello-red: #C41E1E;
      --warm-white: #FAFAF7;
      --stone: #9E9E9E;
      --font-display: "Cormorant Garamond", Georgia, serif;
      --font-body: "Outfit", system-ui, sans-serif;
      --ease-primary: cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --dur-micro: 200ms;
      --dur-standard: 600ms;
      --dur-dramatic: 900ms;
      --dur-cinematic: 1200ms;
    }

    /* === RESET === */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
    img, video { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* === CRAFT SIGNALS === */
    ::selection { background: var(--raffaello-red); color: var(--parchment); }
    ::-moz-selection { background: var(--raffaello-red); color: var(--parchment); }

    /* === GLOBAL TYPOGRAPHY === */
    body {
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--salon-black);
      background: var(--parchment);
    }

    h1, h2, h3, h4 {
      font-family: var(--font-display);
      line-height: 1.05;
      text-wrap: balance;
      letter-spacing: -0.01em;
    }
    h1 { font-size: clamp(3rem, 7vw, 6rem); font-weight: 300; }
    h2 { font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 300; }
    h3 { font-size: clamp(1.5rem, 2.5vw, 2.25rem); font-weight: 400; }
    h4 { font-size: clamp(1.125rem, 1.5vw, 1.5rem); font-weight: 600; }

    p { max-width: 65ch; }

    /* === LAYOUT === */
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
    }

    section { padding: clamp(5rem, 10vw, 7.5rem) 0; }

    /* === DARK SECTIONS === */
    .dark-section {
      background: var(--salon-black);
      color: var(--parchment);
    }
    .dark-section p, .dark-section .caption { color: var(--stone); }

    /* === LIGHT SECTION === */
    .light-section { background: var(--warm-white); }

    /* === BUTTON === */
    .btn {
      display: inline-block;
      padding: 1rem 2.5rem;
      font-family: var(--font-body);
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: background var(--dur-micro) var(--ease-primary), color var(--dur-micro) var(--ease-primary);
    }
    .btn-primary {
      background: var(--raffaello-red);
      color: var(--warm-white);
    }
    .btn-primary:hover { background: #a01818; }
    .btn-outline {
      background: transparent;
      color: var(--parchment);
      border: 1px solid var(--stone);
    }
    .btn-outline:hover {
      border-color: var(--parchment);
      color: var(--warm-white);
    }
    .btn-dark {
      background: var(--salon-black);
      color: var(--parchment);
    }
    .btn-dark:hover { background: #2a2a2a; }

    /* === EYEBROW === */
    .eyebrow {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--stone);
    }

    /* === IMAGES === */
    .img-portrait {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      object-position: top center;
    }
    .img-wide {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
    }

    /* === ANIMATION BASE === */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity var(--dur-standard) var(--ease-primary),
                  transform var(--dur-standard) var(--ease-primary);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.12s; }
    .reveal-delay-2 { transition-delay: 0.24s; }
    .reveal-delay-3 { transition-delay: 0.36s; }

    /* === REDUCED MOTION === */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      .reveal { opacity: 1; transform: none; }
      html { scroll-behavior: auto; }
    }

    /* === DIVIDER === */
    .rule {
      display: block;
      width: 40px;
      height: 1px;
      background: var(--raffaello-red);
      margin-bottom: 2rem;
    }
    .rule-stone {
      background: var(--stone);
    }
  </style>
</head>
<body data-hero={hasDarkHero ? "dark" : "light"}>
  <!-- NAV -->
  <header id="site-nav">
    <nav class="container">
      <a href="/" class="nav-logo" aria-label="Raffaello Salon home">
        <img src="https://irp.cdn-website.com/be09994b/dms3rep/multi/Raffaello+Logo+-+Red.png"
             alt="Raffaello Salon" width="140" height="40" loading="eager" />
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" role="list">
        <li><a href="/services">Services</a></li>
        <li><a href="/team">The Team</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="tel:4169290021" class="nav-cta">(416) 929-0021</a></li>
      </ul>
    </nav>
  </header>

  <!-- PAGE CONTENT -->
  <main id="main">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="site-footer dark-section">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="https://irp.cdn-website.com/be09994b/dms3rep/multi/Raffaello+Logo+-+Red.png"
             alt="Raffaello Salon" width="120" height="36" loading="lazy" />
        <p>Since 1968.</p>
      </div>
      <div class="footer-col">
        <p class="eyebrow">Location</p>
        <address>
          132 Cumberland Street<br />
          2nd Floor<br />
          Toronto, ON M5R 1A6
        </address>
      </div>
      <div class="footer-col">
        <p class="eyebrow">Hours</p>
        <p>Tue — Wed — Fri: 9am – 5pm</p>
        <p>Thursday: 9am – 7pm</p>
        <p>Saturday: 8:30am – 5pm</p>
        <p>Sun — Mon: Closed</p>
      </div>
      <div class="footer-col">
        <p class="eyebrow">Contact</p>
        <a href="tel:4169290021">(416) 929-0021</a>
        <a href="mailto:info@raffaellosalon.com">info@raffaellosalon.com</a>
        <div class="footer-social">
          <a href="https://instagram.com/raffaellosalon" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a>
          <a href="https://facebook.com/raffaellosalon" aria-label="Facebook" target="_blank" rel="noopener">Facebook</a>
        </div>
      </div>
    </div>
    <div class="container footer-bottom">
      <p class="caption">© 2026 Raffaello Salon. All rights reserved.</p>
    </div>
  </footer>

  <style>
    /* NAV */
    #site-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      transition: background var(--dur-standard) var(--ease-primary),
                  border-color var(--dur-standard) var(--ease-primary);
    }
    [data-hero="dark"] #site-nav { background: transparent; border-bottom: 1px solid transparent; }
    [data-hero="light"] #site-nav,
    #site-nav.scrolled { background: rgba(250,250,247,0.96); border-bottom: 1px solid rgba(0,0,0,0.08); }
    [data-hero="dark"] #site-nav:not(.scrolled) .nav-links a { color: rgba(244,240,232,0.85); }
    [data-hero="dark"] #site-nav:not(.scrolled) .nav-links a:hover { color: var(--warm-white); }
    [data-hero="dark"] #site-nav:not(.scrolled) .nav-cta { border-color: rgba(244,240,232,0.4); }
    [data-hero="dark"] #site-nav:not(.scrolled) .nav-toggle span { background: var(--parchment); }

    #site-nav nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    .nav-logo img { height: 36px; width: auto; }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--salon-black);
      transition: color var(--dur-micro) var(--ease-primary);
    }
    .nav-links a:hover { color: var(--raffaello-red); }
    .nav-cta {
      padding: 0.6rem 1.5rem;
      border: 1px solid var(--salon-black);
      transition: background var(--dur-micro) var(--ease-primary), color var(--dur-micro) var(--ease-primary) !important;
    }
    .nav-cta:hover { background: var(--salon-black) !important; color: var(--parchment) !important; }
    .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
    .nav-toggle span { display: block; width: 24px; height: 1px; background: var(--salon-black); transition: all var(--dur-micro) var(--ease-primary); }

    @media (max-width: 768px) {
      .nav-toggle { display: flex; }
      .nav-links {
        position: fixed;
        top: 72px; left: 0; right: 0;
        flex-direction: column;
        background: var(--warm-white);
        padding: 2rem;
        gap: 1.5rem;
        display: none;
        border-top: 1px solid rgba(0,0,0,0.08);
      }
      .nav-links.open { display: flex; }
    }

    /* FOOTER */
    .site-footer { padding: clamp(3rem,6vw,5rem) 0 2rem; }
    .footer-grid {
      display: grid;
      grid-template-columns: 1fr repeat(3, auto);
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      align-items: start;
    }
    .footer-brand p { font-family: var(--font-display); font-size: 1.25rem; font-style: italic; color: var(--stone); margin-top: 1rem; }
    .footer-col .eyebrow { color: var(--stone); margin-bottom: 1rem; }
    .footer-col address, .footer-col p { font-style: normal; font-size: 0.875rem; line-height: 1.8; color: rgba(244,240,232,0.6); }
    .footer-col a { display: block; font-size: 0.875rem; color: rgba(244,240,232,0.6); margin-bottom: 0.5rem; transition: color var(--dur-micro) var(--ease-primary); }
    .footer-col a:hover { color: var(--parchment); }
    .footer-social { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .footer-bottom { padding-top: 1.5rem; }
    .caption { font-size: 0.75rem; color: var(--stone); }
    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    // Nav scroll behavior — dark hero detection
    const nav = document.getElementById('site-nav');
    const isDarkHero = document.body.dataset.hero === 'dark';
    const solidState = () => window.scrollY > 60 || !isDarkHero;

    function updateNav() {
      nav.classList.toggle('scrolled', solidState());
    }
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });

    // Mobile menu
    const toggle = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      links.classList.toggle('open');
    });

    // Intersection observer for reveal animations
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.15 });
    reveals.forEach(el => observer.observe(el));
  </script>
</body>
</html>
